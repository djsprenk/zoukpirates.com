---
layout: layouts/base.njk
title: Meet the Crew
description: Meet the Zouk Pirates — the Boston-based trio behind the events.
---

<h1>Meet the Crew</h1>

<ul class="crew-grid">
  {% for member in crew %}
  <li class="crew-card">
    <div class="crew-card-photo">
      {% if member.photo %}
      <img
        src="{{ member.photo }}"
        alt="{{ member.name }}"
        {%
        if
        member.photoPosition
        or
        member.photoScale
        %}style="{% if member.photoPosition %}object-position: {{ member.photoPosition }};{% endif %}{% if member.photoScale %}transform: scale({{ member.photoScale }});{% endif %}"
        {%
        endif
        %}
      />
      {% endif %}
    </div>
    <div class="crew-card-body">
      <div>
        <h2 class="crew-card-name">{{ member.name }}</h2>
        {% if member.aka %}
        <p class="crew-card-aka">{{ member.aka }}</p>
        {% endif %}
      </div>
      <span class="crew-card-role">{{ member.role }}</span>
      <p class="crew-card-bio">{{ member.bio | safe }}</p>
      {% if member.social %}
      <ul class="crew-card-social">
        {% if member.social.instagram %}
        <li>
          <a
            href="{{ member.social.instagram }}"
            target="_blank"
            rel="noopener"
            class="crew-social-link"
            aria-label="Instagram"
          >
            <i class="fa-brands fa-instagram" aria-hidden="true"></i>
          </a>
        </li>
        {% endif %} {% if member.social.facebook %}
        <li>
          <a
            href="{{ member.social.facebook }}"
            target="_blank"
            rel="noopener"
            class="crew-social-link"
            aria-label="Facebook"
          >
            <i class="fa-brands fa-facebook" aria-hidden="true"></i>
          </a>
        </li>
        {% endif %} {% if member.social.mixcloud %}
        <li>
          <a
            href="{{ member.social.mixcloud }}"
            target="_blank"
            rel="noopener"
            class="crew-social-link"
            aria-label="Mixcloud"
          >
            <i class="fa-brands fa-mixcloud" aria-hidden="true"></i>
          </a>
        </li>
        {% endif %} {% if member.social.soundcloud %}
        <li>
          <a
            href="{{ member.social.soundcloud }}"
            target="_blank"
            rel="noopener"
            class="crew-social-link"
            aria-label="SoundCloud"
          >
            <i class="fa-brands fa-soundcloud" aria-hidden="true"></i>
          </a>
        </li>
        {% endif %} {% if member.social.patreon %}
        <li>
          <a
            href="{{ member.social.patreon }}"
            target="_blank"
            rel="noopener"
            class="crew-social-link"
            aria-label="Patreon"
          >
            <i class="fa-brands fa-patreon" aria-hidden="true"></i>
          </a>
        </li>
        {% endif %} {% if member.social.website %}
        <li>
          <a
            href="{{ member.social.website }}"
            target="_blank"
            rel="noopener"
            class="crew-social-link"
            aria-label="Website"
          >
            <i class="fa-solid fa-globe" aria-hidden="true"></i>
          </a>
        </li>
        {% endif %} {% if member.social.youtube %}
        <li>
          <a
            href="{{ member.social.youtube }}"
            target="_blank"
            rel="noopener"
            class="crew-social-link"
            aria-label="YouTube"
          >
            <i class="fa-brands fa-youtube" aria-hidden="true"></i>
          </a>
        </li>
        {% endif %}
      </ul>
      {% endif %}
    </div>
  </li>
  {% endfor %}
</ul>

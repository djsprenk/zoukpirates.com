---
layout: layouts/base.njk
title: Meet the Crew
description: Meet the Zouk Pirates — the Boston-based trio behind the events.
---

<h1>Meet the Crew</h1>

<ul class="crew-list">
  {% for member in crew %}
  <li class="crew-member">
    <h2>{{ member.name }}</h2>
    {% if member.aka %}
    <p class="crew-aka">{{ member.aka }}</p>
    {% endif %}
    <p class="crew-role">{{ member.role }}</p>
    <p class="crew-bio">{{ member.bio | safe }}</p>
    {% if member.social %}
    <ul class="crew-social">
      {% if member.social.instagram %}
      <li><a href="{{ member.social.instagram }}">Instagram</a></li>
      {% endif %} {% if member.social.facebook %}
      <li><a href="{{ member.social.facebook }}">Facebook</a></li>
      {% endif %} {% if member.social.mixcloud %}
      <li><a href="{{ member.social.mixcloud }}">Mixcloud</a></li>
      {% endif %} {% if member.social.youtube %}
      <li><a href="{{ member.social.youtube }}">YouTube</a></li>
      {% endif %}
    </ul>
    {% endif %}
  </li>
  {% endfor %}
</ul>
